# Server auth (required)
API_KEY=change_me
JWT_SECRET=change_me_to_a_long_random_string

# Database mode: "real" (default) or "mock" (demo/local)
DB_MODE=real

# Database connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=clarity_db

# Server port
PORT=5000

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# Request hardening
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

